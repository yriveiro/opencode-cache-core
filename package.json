{
  "name": "opencode-cache-core",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "opencodePlugin": true,
  "keywords": [
    "opencode-plugin",
    "cache",
    "search"
  ],
  "files": [
    "src",
    "dist"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "clean": "rm -rf dist node_modules bun.lock",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tailwindcss/cli": "^4.1.3",
    "@types/node": "^22.14.1",
    "bun-types": "^1.3.11",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.3"
  }
}
