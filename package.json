{
  "name": "@yriveiro/opencode-cache-core",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "opencodePlugin": true,
  "description": "OpenCode plugin for cache and search via DevDocs",
  "author": "yriveiro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yriveiro/opencode-cache-core.git"
  },
  "homepage": "https://github.com/yriveiro/opencode-cache-core#readme",
  "bugs": {
    "url": "https://github.com/yriveiro/opencode-cache-core/issues"
  },
  "keywords": [
    "opencode-plugin",
    "cache",
    "search"
  ],
  "files": [
    "src",
    "dist"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.3.17"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "clean": "rm -rf dist node_modules bun.lock",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^22.19.17",
    "bun-types": "^1.3.12",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
