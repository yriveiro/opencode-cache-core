{
	"name": "opencode-cache-core",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"opencodePlugin": true,
	"keywords": [
		"opencode-plugin",
		"cache",
		"search"
	],
	"peerDependencies": {
		"@opencode-ai/plugin": "*"
	},
	"scripts": {
		"tsc": "bun run ./tsc.ts",
		"build": "bun run ./tsc.ts -p tsconfig.json",
		"typecheck": "bun run ./tsc.ts --noEmit -p tsconfig.json",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check .",
		"prepublishOnly": "bun run typecheck && bun run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@tailwindcss/cli": "^4.1.3",
		"@types/node": "^22.14.1",
		"bun-types": "^1.3.11",
		"tailwindcss": "^4.1.3",
		"typescript": "^5.8.3"
	}
}
